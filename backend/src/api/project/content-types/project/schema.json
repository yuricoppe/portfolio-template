{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Case de projeto do portfólio"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "category": {
      "type": "string"
    },
    "year": {
      "type": "string"
    },
    "client": {
      "type": "string"
    },
    "sector": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "gradient": {
      "type": "string"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "statement": {
      "type": "text"
    },
    "statementMuted": {
      "type": "text"
    },
    "challenge": {
      "type": "text"
    },
    "solution": {
      "type": "text"
    },
    "quote": {
      "type": "text"
    },
    "quoteMuted": {
      "type": "text"
    },
    "quoteAuthor": {
      "type": "string"
    },
    "metrics": {
      "type": "component",
      "repeatable": true,
      "component": "shared.metric"
    },
    "gallery": {
      "type": "component",
      "repeatable": true,
      "component": "shared.gallery-item"
    },
    "order": {
      "type": "integer",
      "default": 99
    },
    "featured": {
      "type": "boolean",
      "default": false
    }
  }
}
