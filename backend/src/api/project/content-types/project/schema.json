{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Case de projeto do portfólio"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "category": {
      "type": "string"
    },
    "year": {
      "type": "string"
    },
    "client": {
      "type": "string"
    },
    "sector": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "gradient": {
      "type": "string"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images", "videos"]
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "sections.statement",
        "sections.full-image",
        "sections.text-columns",
        "sections.image-grid",
        "sections.quote",
        "sections.metrics"
      ]
    },
    "order": {
      "type": "integer",
      "default": 99
    },
    "featured": {
      "type": "boolean",
      "default": false
    }
  }
}
